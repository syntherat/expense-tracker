PORT=4000
NODE_ENV=development
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=verify-full
SESSION_SECRET=replace-with-a-long-random-string
SESSION_COOKIE_NAME=expense.sid
CLIENT_ORIGIN=http://localhost:3000
APP_INVITE_BASE_URL=https://app.expensetracker.local/invite

S3_ENABLED=false
AWS_REGION=ap-south-1
AWS_S3_BUCKET=your-bucket-name
AWS_ACCESS_KEY_ID=your-key
AWS_SECRET_ACCESS_KEY=your-secret
AWS_S3_PUBLIC_BASE_URL=https://your-bucket-name.s3.ap-south-1.amazonaws.com
